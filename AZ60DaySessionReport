#------------------------------------------------------------------------------
# Session Processing
#------------------------------------------------------------------------------

Write-Section "Processing Session Records"

$OutputRows = [System.Collections.Generic.List[PSCustomObject]]::new()

foreach ($Session in $RawSessions) {
    $ResolvedUser = "System Account / Unresolved"
    $SessionUserRefNormalised = $null

    if ($SessionUserRefProperty) {
        $SessionUserRef = $Session.$SessionUserRefProperty

        if ($null -ne $SessionUserRef) {
            $SessionUserRefNormalised = Convert-ToNormalisedReferenceString -Value $SessionUserRef

            if ($SessionUserRefNormalised -and $UserMap.ContainsKey($SessionUserRefNormalised)) {
                $ResolvedUser = $UserMap[$SessionUserRefNormalised]
            }
        }
    }

    if ($ResolvedUser -eq "Unknown User") {
        $ResolvedUser = "System Account / Unresolved"
    }

    $VdaHostName = "Unknown"
    $CleanVdaHostName = "unknown"
    $DeliveryGroupName = "Unknown"
    $SessionMachineRefNormalised = $null

    if ($SessionMachineRefProperty) {
        $SessionMachineRef = $Session.$SessionMachineRefProperty

        if ($null -ne $SessionMachineRef) {
            $SessionMachineRefNormalised = Convert-ToNormalisedReferenceString -Value $SessionMachineRef

            if ($SessionMachineRefNormalised -and $MachineNameByReference.ContainsKey($SessionMachineRefNormalised)) {
                $CleanVdaHostName = $MachineNameByReference[$SessionMachineRefNormalised]
            }

            if ($SessionMachineRefNormalised -and $MachineLookupByReference.ContainsKey($SessionMachineRefNormalised)) {
                $MatchedMachine = $MachineLookupByReference[$SessionMachineRefNormalised]

                if ($MachineNameProperty -and $MatchedMachine.$MachineNameProperty) {
                    $VdaHostName = [string]$MatchedMachine.$MachineNameProperty
                }
                else {
                    $VdaHostName = $CleanVdaHostName
                }
            }
        }
    }

    if ($VdaHostName -eq "Unknown" -and $CleanVdaHostName -ne "unknown") {
        $VdaHostName = $CleanVdaHostName
    }

    # Delivery Group resolution. This is inventory/location context only.
    $DirectSessionGroupName = Get-ObjectPropertyValue `
        -InputObject $Session `
        -PropertyNames @("DesktopGroupName", "DeliveryGroupName", "GroupName", "PublishedDesktopName", "DesktopName")

    if ($DirectSessionGroupName) {
        $DeliveryGroupName = [string]$DirectSessionGroupName
    }

    if ($DeliveryGroupName -eq "Unknown" -and $SessionMachineRefNormalised) {
        if ($MachineGroupNameByReference.ContainsKey($SessionMachineRefNormalised)) {
            $DeliveryGroupName = $MachineGroupNameByReference[$SessionMachineRefNormalised]
        }
    }

    if ($DeliveryGroupName -eq "Unknown" -and $MachineGroupNameByCleanName.ContainsKey($CleanVdaHostName)) {
        $DeliveryGroupName = $MachineGroupNameByCleanName[$CleanVdaHostName]
    }

    if ($DeliveryGroupName -eq "Unknown") {
        $RawSessionGroupRef = Get-ObjectPropertyValue `
            -InputObject $Session `
            -PropertyNames @(
                "DesktopGroupId",
                "DesktopGroupKey",
                "DesktopGroupUid",
                "DesktopGroupUId",
                "DeliveryGroupId",
                "DeliveryGroupKey",
                "GroupId",
                "GroupKey"
            )

        if ($RawSessionGroupRef) {
            $GroupRefKey = Convert-ToNormalisedReferenceString -Value $RawSessionGroupRef

            if ($GroupRefKey -and $GroupMap.ContainsKey($GroupRefKey)) {
                $DeliveryGroupName = $GroupMap[$GroupRefKey]
            }
        }
    }

    if ($DeliveryGroupName -eq "Unknown" -and $SessionMachineRefNormalised) {
        if ($MachineGroupReferenceByMachineReference.ContainsKey($SessionMachineRefNormalised)) {
            $GroupRefKey = Convert-ToNormalisedReferenceString -Value $MachineGroupReferenceByMachineReference[$SessionMachineRefNormalised]

            if ($GroupRefKey -and $GroupMap.ContainsKey($GroupRefKey)) {
                $DeliveryGroupName = $GroupMap[$GroupRefKey]
            }
        }
    }

    if ($DeliveryGroupName -eq "Unknown" -and $BrokerFallbackMaps.MachineGroupNameByCleanName.ContainsKey($CleanVdaHostName)) {
        $DeliveryGroupName = $BrokerFallbackMaps.MachineGroupNameByCleanName[$CleanVdaHostName]
    }

    $SessionStartDate = if ($SessionStartDateProperty) {
        $Session.$SessionStartDateProperty
    }
    else {
        $null
    }

    $SortableStartTime = $null
    $LogonEpoch = $null

    if ($SessionStartDate) {
        try {
            $SortableStartTime = [DateTime]$SessionStartDate
            $UtcStart = $SortableStartTime.ToUniversalTime()
            $LogonEpoch = [int64](([DateTimeOffset]$UtcStart).ToUnixTimeMilliseconds())
        }
        catch {
            $SortableStartTime = $null
            $LogonEpoch = $null
        }
    }

    $SessionTypeValue = if ($SessionTypeProperty) {
        $Session.$SessionTypeProperty
    }
    else {
        $null
    }

    $IsDesktopSession = Test-IsDesktopSession -SessionTypeValue $SessionTypeValue
    $IsApplicationSession = Test-IsApplicationSession -SessionTypeValue $SessionTypeValue
    $SessionRefs = Get-SessionCandidateReferenceValues -Session $Session

    $PublishedApplication = ""
    $PublishedDesktop = ""
    $ApplicationEvidenceSource = ""
    $DesktopEvidenceSource = ""

    $MachineKindText = $null

    if ($MachineKindByCleanName.ContainsKey($CleanVdaHostName)) {
        $MachineKindText = $MachineKindByCleanName[$CleanVdaHostName]
    }

    if ($BrokerFallbackMaps.MachineKindByCleanName.ContainsKey($CleanVdaHostName)) {
        $MachineKindText = $BrokerFallbackMaps.MachineKindByCleanName[$CleanVdaHostName]
    }

    $MachineLooksLikeDesktop = Test-MachineLooksLikeDesktop `
        -CleanMachineName $CleanVdaHostName `
        -MachineKindText $MachineKindText

    # -------------------------------------------------------------------------
    # Published Application resolution - independent signal.
    # Do not infer application from Delivery Group alone.
    # -------------------------------------------------------------------------

    $DirectApplicationName = Get-ObjectPropertyValue `
        -InputObject $Session `
        -PropertyNames @(
            "PublishedApplicationName",
            "ApplicationName",
            "AppName",
            "BrowserName",
            "PublishedResourceName",
            "ResourceName"
        )

    if ($DirectApplicationName) {
        $PublishedApplication = [string]$DirectApplicationName
        $ApplicationEvidenceSource = "SessionDirectApplicationName"
    }

    if ((Test-Blank $PublishedApplication) -and $SessionApplicationRefProperty) {
        $AppId = $Session.$SessionApplicationRefProperty

        if ($AppId) {
            $AppKey = Convert-ToNormalisedReferenceString -Value $AppId

            if ($AppKey -and $ApplicationLookupMap.ContainsKey($AppKey)) {
                $PublishedApplication = $ApplicationLookupMap[$AppKey]
                $ApplicationEvidenceSource = "SessionApplicationReference"
            }
        }
    }

    if (Test-Blank $PublishedApplication) {
        foreach ($SessionRef in $SessionRefs) {
            if ($SessionApplicationNameMap.ContainsKey($SessionRef)) {
                $PublishedApplication = (($SessionApplicationNameMap[$SessionRef] | Sort-Object -Unique) -join ", ")
                $ApplicationEvidenceSource = "ExactApplicationEvidenceReference"
                break
            }
        }
    }

    if (Test-Blank $PublishedApplication) {
        $EvidenceAppName = Resolve-ApplicationFromEvidence `
            -SessionRefs $SessionRefs `
            -SessionUserRef $SessionUserRefNormalised `
            -SessionUserName $ResolvedUser `
            -SessionMachineRef $SessionMachineRefNormalised `
            -CleanVdaHostName $CleanVdaHostName `
            -SessionStartTime $SortableStartTime `
            -ApplicationEvidence @($ApplicationEvidenceRows)

        if (-not (Test-Blank $EvidenceAppName)) {
            $PublishedApplication = $EvidenceAppName
            $ApplicationEvidenceSource = "CorrelatedApplicationEvidence"
            $IsApplicationSession = $true
        }
    }

    if (Test-Blank $PublishedApplication) {
        $SingleFallbackApp = Resolve-SingleApplicationFallback `
            -SessionUserRef $SessionUserRefNormalised `
            -SessionUserName $ResolvedUser `
            -ApplicationEvidence @($ApplicationEvidenceRows)

        if (-not (Test-Blank $SingleFallbackApp)) {
            $PublishedApplication = $SingleFallbackApp
            $ApplicationEvidenceSource = "SingleUserApplicationEvidence"
            $IsApplicationSession = $true
        }
    }

    if (Test-Blank $PublishedApplication) {
        $BrokerUserApp = Resolve-ApplicationFromBrokerUserFallback `
            -SessionUserName $ResolvedUser `
            -SessionUserRef $SessionUserRefNormalised `
            -BrokerFallbackMaps $BrokerFallbackMaps

        if (-not (Test-Blank $BrokerUserApp)) {
            $PublishedApplication = $BrokerUserApp
            $ApplicationEvidenceSource = "BrokerUserApplicationEntitlement"
            $IsApplicationSession = $true
        }
    }

    # -------------------------------------------------------------------------
    # Published Desktop resolution - independent but controlled.
    # -------------------------------------------------------------------------

    $ResolvedDesktopName = ""
    $HasDesktopEvidence = $false

    $DirectDesktopName = Get-ObjectPropertyValue `
        -InputObject $Session `
        -PropertyNames @(
            "PublishedDesktopName",
            "PublishedDesktop",
            "DesktopName"
        )

    if ($DirectDesktopName) {
        $ResolvedDesktopName = [string]$DirectDesktopName
        $HasDesktopEvidence = $true
        $DesktopEvidenceSource = "SessionDirectDesktopName"
    }

    if (-not $HasDesktopEvidence -and $IsDesktopSession) {
        $BrokerUserDesktop = Resolve-DesktopFromBrokerUserFallback `
            -SessionUserName $ResolvedUser `
            -SessionUserRef $SessionUserRefNormalised `
            -BrokerFallbackMaps $BrokerFallbackMaps

        if (-not (Test-Blank $BrokerUserDesktop)) {
            $ResolvedDesktopName = $BrokerUserDesktop
            $HasDesktopEvidence = $true
            $DesktopEvidenceSource = "BrokerUserDesktopEntitlement"
        }
    }

    # Controlled SessionType fallback.
    # This restores Batman desktop rows where entitlement data is absent,
    # while preventing app-only users from inheriting desktops when Broker proves app-only.
    if (-not $HasDesktopEvidence -and $IsDesktopSession) {
        $IsClearlyAppOnlyUser = Test-IsClearlyAppOnlyUser `
            -SessionUserName $ResolvedUser `
            -SessionUserRef $SessionUserRefNormalised `
            -BrokerFallbackMaps $BrokerFallbackMaps

        if (-not $IsClearlyAppOnlyUser) {
            if (-not (Test-Blank $DeliveryGroupName) -and $DeliveryGroupName -ne "Unknown") {
                $ResolvedDesktopName = $DeliveryGroupName
            }
            else {
                $ResolvedDesktopName = "Published Desktop"
            }

            $HasDesktopEvidence = $true
            $DesktopEvidenceSource = "SessionTypeControlledFallback"
        }
    }

    if (-not $HasDesktopEvidence -and $IsDesktopSession -and $MachineLooksLikeDesktop) {
        if (-not (Test-Blank $DeliveryGroupName) -and $DeliveryGroupName -ne "Unknown") {
            $ResolvedDesktopName = $DeliveryGroupName
        }
        else {
            $ResolvedDesktopName = "Published Desktop"
        }

        $HasDesktopEvidence = $true
        $DesktopEvidenceSource = "DesktopSessionOnDesktopMachine"
    }

    if (-not $HasDesktopEvidence -and
        (Test-Blank $PublishedApplication) -and
        $MachineLooksLikeDesktop) {

        if (-not (Test-Blank $DeliveryGroupName) -and $DeliveryGroupName -ne "Unknown") {
            $ResolvedDesktopName = $DeliveryGroupName
        }
        else {
            $ResolvedDesktopName = "Published Desktop"
        }

        $HasDesktopEvidence = $true
        $DesktopEvidenceSource = "DesktopMachineFallback"
    }

    if ($HasDesktopEvidence) {
        $PublishedDesktop = $ResolvedDesktopName
    }
    else {
        $PublishedDesktop = ""
    }

    if ((Test-Blank $PublishedApplication) -and $IsApplicationSession -and -not $HasDesktopEvidence) {
        $PublishedApplication = "Published Application"
        $ApplicationEvidenceSource = "GenericApplicationSession"
    }

    $SessionCpu = "No Data"
    $SessionMem = "No Data"

    if ($PerformanceTelemetryMap.ContainsKey($CleanVdaHostName)) {
        $Metric = $PerformanceTelemetryMap[$CleanVdaHostName]
        $SessionCpu = Format-CpuMetric -Value $Metric.Cpu
        $SessionMem = Format-MemoryMetric -Value $Metric.Mem -SourceProperty $Metric.MemoryProperty
    }

    $LocalLogonTime = "Unknown"

    if ($SessionStartDate) {
        try {
            if ($null -eq $SortableStartTime) {
                $SortableStartTime = [DateTime]$SessionStartDate
            }

            $LocalLogonTime = $SortableStartTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
        }
        catch {
            $LocalLogonTime = [string]$SessionStartDate
        }
    }

    [void]$OutputRows.Add([PSCustomObject]@{
        User                    = $ResolvedUser
        "Delivery Group"        = $DeliveryGroupName
        "Published Application" = $PublishedApplication
        "Published Desktop"     = $PublishedDesktop
        "VDA Host"              = $VdaHostName
        CPU                     = $SessionCpu
        MEM                     = $SessionMem
        "Logon Time"            = $LocalLogonTime
        LogonEpoch              = $LogonEpoch
        SortableStartTime       = $SortableStartTime
        ApplicationEvidence     = $ApplicationEvidenceSource
        DesktopEvidence         = $DesktopEvidenceSource
    })
}

$SortedOutputRows = @(
    $OutputRows |
        Sort-Object User, SortableStartTime -Descending
)

$FinalExportRows = @(
