function Resolve-ODataNextLink {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$CurrentUri,

        [Parameter(Mandatory)]
        [string]$NextLink
    )

    if (Test-Blank $NextLink) {
        return $null
    }

    $NextLink = $NextLink.Trim()

    if ($NextLink -match '^https?://') {
        return $NextLink
    }

    $CurrentUriObject = [System.Uri]::new($CurrentUri)

    $CurrentBaseWithoutQuery = '{0}://{1}{2}' -f `
        $CurrentUriObject.Scheme,
        $CurrentUriObject.Authority,
        $CurrentUriObject.AbsolutePath

    if ($NextLink.StartsWith("/")) {
        return '{0}://{1}{2}' -f `
            $CurrentUriObject.Scheme,
            $CurrentUriObject.Authority,
            $NextLink
    }

    if ($NextLink.StartsWith("?")) {
        return '{0}{1}' -f $CurrentBaseWithoutQuery, $NextLink
    }

    if ($NextLink.StartsWith('$')) {
        return '{0}?{1}' -f $CurrentBaseWithoutQuery, $NextLink
    }

    $ResolvedUri = [System.Uri]::new($CurrentUriObject, $NextLink)
    return $ResolvedUri.AbsoluteUri
}

function Test-AbsoluteHttpUri {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$Uri
    )

    if (Test-Blank $Uri) {
        return $false
    }

    $ParsedUri = $null

    if (-not [System.Uri]::TryCreate($Uri, [System.UriKind]::Absolute, [ref]$ParsedUri)) {
        return $false
    }

    return ($ParsedUri.Scheme -eq "http" -or $ParsedUri.Scheme -eq "https")
}

function Test-ODataEndpoint {
    param(
        [Parameter(Mandatory)]
        [string]$BaseUrl
    )

    try {
        $MetadataUri = "$BaseUrl/`$metadata"

        Invoke-WebRequest `
            -Uri $MetadataUri `
            -UseDefaultCredentials `
            -UseBasicParsing `
            -Method Get `
            -TimeoutSec 30 `
            -ErrorAction Stop | Out-Null

        return $true
    }
    catch {
        Write-Verbose "Endpoint test failed for '$BaseUrl'. $($_.Exception.Message)"
        return $false
    }
}

function Resolve-ControllerAddress {
    param(
        [Parameter(Mandatory)]
        [string]$InputControllerAddress
    )

    if ($InputControllerAddress -ne "localhost") {
        return $InputControllerAddress
    }

    Import-CitrixBrokerSnapInIfAvailable

    try {
        $ResolvedController = Get-BrokerController -ErrorAction Stop |
            Select-Object -First 1 -ExpandProperty DNSName

        if (-not (Test-Blank $ResolvedController)) {
            return $ResolvedController
        }
    }
    catch {
        Write-Warning "Could not auto-resolve a Citrix Delivery Controller. Falling back to localhost. $($_.Exception.Message)"
    }

    return $InputControllerAddress
}

function Resolve-MonitorODataBaseUrl {
    param(
        [Parameter(Mandatory)]
        [string]$ControllerAddress,

        [switch]$PreferHttp
    )

    if ($PreferHttp) {
        $CandidateBaseUrls = @(
            "http://$ControllerAddress/Citrix/Monitor/OData/v4/Data",
            "https://$ControllerAddress/Citrix/Monitor/OData/v4/Data"
        )
    }
    else {
        $CandidateBaseUrls = @(
            "https://$ControllerAddress/Citrix/Monitor/OData/v4/Data",
            "http://$ControllerAddress/Citrix/Monitor/OData/v4/Data"
        )
    }

    foreach ($CandidateBaseUrl in $CandidateBaseUrls) {
        Write-Host "Testing Monitor OData endpoint: $CandidateBaseUrl" -ForegroundColor DarkCyan

        if (Test-ODataEndpoint -BaseUrl $CandidateBaseUrl) {
            Write-Host "Using Monitor OData endpoint: $CandidateBaseUrl" -ForegroundColor Green
            return $CandidateBaseUrl
        }
    }

    throw "Unable to locate a reachable Citrix Monitor OData v4 endpoint on controller '$ControllerAddress'."
}

function New-ODataEntityUri {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$BaseUrl,

        [Parameter(Mandatory)]
        [string]$EntitySetName,

        [string]$Filter
    )

    if (Test-Blank $BaseUrl) {
        throw "BaseUrl is empty before building OData URI."
    }

    if (Test-Blank $EntitySetName) {
        throw "EntitySetName is empty before building OData URI."
    }

    $RootUri = "{0}/{1}" -f $BaseUrl.TrimEnd('/'), $EntitySetName.TrimStart('/')

    if (-not (Test-Blank $Filter)) {
        $EncodedFilter = [System.Uri]::EscapeDataString($Filter)
        $FinalUri = '{0}?$filter={1}' -f $RootUri, $EncodedFilter
    }
    else {
        $FinalUri = $RootUri
    }

    if (-not (Test-AbsoluteHttpUri -Uri $FinalUri)) {
        throw "Invalid OData URI constructed: '$FinalUri'"
    }

    return $FinalUri
}

function Invoke-ODataPagedQuery {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$Uri,

        [int]$TimeoutSec = 120
    )

    if (-not (Test-AbsoluteHttpUri -Uri $Uri)) {
        throw "Initial OData URI is not a valid absolute HTTP/HTTPS URI: '$Uri'"
    }

    $Results = [System.Collections.Generic.List[object]]::new()
    $NextUri = $Uri
    $PageNumber = 0

    while ($NextUri) {
        $PageNumber++

        if (-not (Test-AbsoluteHttpUri -Uri $NextUri)) {
            throw "Paged OData URI is not a valid absolute HTTP/HTTPS URI: '$NextUri'"
        }

        $script:LastODataUri = $NextUri
        Write-Verbose "Querying OData page $PageNumber`: $NextUri"

        $Response = Invoke-RestMethod `
            -Uri $NextUri `
            -UseDefaultCredentials `
            -Method Get `
            -TimeoutSec $TimeoutSec `
            -ErrorAction Stop

        if ($null -ne $Response.value) {
            foreach ($Item in $Response.value) {
                [void]$Results.Add($Item)
            }
        }

        $NextUri = $null

        $NextLinkProperty = $Response.PSObject.Properties |
            Where-Object { $_.Name -match 'nextLink$' } |
            Select-Object -First 1

        if ($NextLinkProperty -and $NextLinkProperty.Value) {
            $NextUri = Resolve-ODataNextLink `
                -CurrentUri $script:LastODataUri `
                -NextLink ([string]$NextLinkProperty.Value)
        }
    }

    return $Results
}

