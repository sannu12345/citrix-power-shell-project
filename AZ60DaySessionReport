function Get-ODataEntitySetCatalogue {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [xml]$Metadata
    )

    $Catalogue = [System.Collections.Generic.List[object]]::new()
    $EntityTypeMap = @{}

    $SchemaNodes = $Metadata.SelectNodes("//*[local-name()='Schema']")

    foreach ($Schema in $SchemaNodes) {
        $Namespace = [string]$Schema.Namespace
        $EntityTypeNodes = $Schema.SelectNodes("./*[local-name()='EntityType']")

        foreach ($EntityType in $EntityTypeNodes) {
            $TypeName = [string]$EntityType.Name
            $FullTypeName = "$Namespace.$TypeName"

            $PropertyNames = @(
                $EntityType.SelectNodes("./*[local-name()='Property']") |
                    ForEach-Object { [string]$_.Name }
            )

            $NavigationPropertyNames = @(
                $EntityType.SelectNodes("./*[local-name()='NavigationProperty']") |
                    ForEach-Object { [string]$_.Name }
            )

            $EntityTypeMap[$FullTypeName] = [PSCustomObject]@{
                Name                 = $TypeName
                FullName             = $FullTypeName
                Properties           = $PropertyNames
                NavigationProperties = $NavigationPropertyNames
            }
        }
    }

    $EntitySetNodes = $Metadata.SelectNodes("//*[local-name()='EntityContainer']/*[local-name()='EntitySet']")

    foreach ($EntitySet in $EntitySetNodes) {
        $EntitySetName = [string]$EntitySet.Name
        $EntityTypeRef = [string]$EntitySet.EntityType

        if ($EntityTypeMap.ContainsKey($EntityTypeRef)) {
            $TypeInfo = $EntityTypeMap[$EntityTypeRef]

            [void]$Catalogue.Add([PSCustomObject]@{
                EntitySetName        = $EntitySetName
                EntityType           = $EntityTypeRef
                TypeName             = $TypeInfo.Name
                Properties           = $TypeInfo.Properties
                NavigationProperties = $TypeInfo.NavigationProperties
            })
        }
    }

    return $Catalogue
}

function Resolve-ODataEntitySetBySignature {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object[]]$Catalogue,

        [string[]]$RequiredAll = @(),

        [string[]]$RequiredAny = @(),

        [string[]]$Preferred = @(),

        [string]$Purpose = "Unknown"
    )

    $Candidates = foreach ($Entity in $Catalogue) {
        $Properties = @($Entity.Properties)
        $HasAllRequired = $true

        foreach ($RequiredProperty in $RequiredAll) {
            if ($Properties -notcontains $RequiredProperty) {
                $HasAllRequired = $false
                break
            }
        }

        if (-not $HasAllRequired) {
            continue
        }

        $AnyMatches = @()

        if ($RequiredAny.Count -gt 0) {
            $AnyMatches = @($RequiredAny | Where-Object { $Properties -contains $_ })

            if ($AnyMatches.Count -eq 0) {
                continue
            }
        }

        $PreferredMatches = @($Preferred | Where-Object { $Properties -contains $_ })

        [PSCustomObject]@{
            EntitySetName         = $Entity.EntitySetName
            EntityType            = $Entity.EntityType
            TypeName              = $Entity.TypeName
            Properties            = $Entity.Properties
            NavigationProperties  = $Entity.NavigationProperties
            RequiredAnyMatchCount = $AnyMatches.Count
            PreferredMatchCount   = $PreferredMatches.Count
            TotalMatchScore       = ($RequiredAll.Count * 20) + ($AnyMatches.Count * 10) + ($PreferredMatches.Count * 3)
        }
    }

    $BestMatch = $Candidates |
        Sort-Object TotalMatchScore, PreferredMatchCount, RequiredAnyMatchCount -Descending |
        Select-Object -First 1

    if (-not $BestMatch) {
        Write-Warning "Could not resolve an OData entity set for '$Purpose'."
        return $null
    }

    Write-Host "Resolved '$Purpose' to entity set '$($BestMatch.EntitySetName)'." -ForegroundColor DarkCyan
    return $BestMatch
}

function Resolve-FirstAvailableProperty {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [AllowEmptyCollection()]
        [string[]]$AvailableProperties,

        [Parameter(Mandatory)]
        [string[]]$PreferredNames,

        [Parameter(Mandatory)]
        [string]$Purpose,

        [switch]$Quiet
    )

    foreach ($Name in $PreferredNames) {
        if ($AvailableProperties -contains $Name) {
            return $Name
        }
    }

    if (-not $Quiet) {
        Write-Warning "Could not resolve property for '$Purpose'. Tested: $($PreferredNames -join ', ')"
    }

    return $null
}

