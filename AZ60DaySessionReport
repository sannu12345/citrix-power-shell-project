    $GroupsTable = @()
    if ($GroupEntity) {
        $GroupsTable = Invoke-ODataPagedQuery -Uri (
            New-ODataEntityUri -BaseUrl $BaseUrl -EntitySetName $GroupEntity.EntitySetName
        )
    }

    $ApplicationsTable = @()
    if ($ApplicationEntity) {
        $ApplicationsTable = Invoke-ODataPagedQuery -Uri (
            New-ODataEntityUri -BaseUrl $BaseUrl -EntitySetName $ApplicationEntity.EntitySetName
        )
    }

    $SessionFilter = "$SessionStartDateProperty ge $PastDateUTC"

    $RawSessions = Invoke-ODataPagedQuery -Uri (
        New-ODataEntityUri `
            -BaseUrl $BaseUrl `
            -EntitySetName $SessionEntity.EntitySetName `
            -Filter $SessionFilter
    )

    $MetricTables = @{}

    foreach ($MetricEntity in $MetricEntities) {
        $MetricDateProperty = Resolve-FirstAvailableProperty `
            -AvailableProperties $MetricEntity.Properties `
            -PreferredNames @("SummaryDate", "CreatedDate", "StartDate", "Date") `
            -Purpose "Metric date for $($MetricEntity.EntitySetName)" `
            -Quiet

        if (Test-Blank $MetricDateProperty) {
            continue
        }

        $MetricFilter = "$MetricDateProperty ge $PastDateUTC"

        try {
            $MetricTables[$MetricEntity.EntitySetName] = Invoke-ODataPagedQuery -Uri (
                New-ODataEntityUri `
                    -BaseUrl $BaseUrl `
                    -EntitySetName $MetricEntity.EntitySetName `
                    -Filter $MetricFilter
            )
        }
        catch {
            Write-Warning "Metric extraction failed for '$($MetricEntity.EntitySetName)'. $($_.Exception.Message)"
        }
    }

    $ApplicationUsageTables = @{}

    foreach ($ApplicationUsageEntity in $ApplicationUsageEntities) {
        $UsageDateProperty = Resolve-FirstAvailableProperty `
            -AvailableProperties $ApplicationUsageEntity.Properties `
            -PreferredNames @("StartDate", "CreatedDate", "LaunchTime", "LaunchDate", "ConnectionStartDate", "LogOnStartDate", "EndDate", "Date", "SummaryDate") `
            -Purpose "Application usage date for $($ApplicationUsageEntity.EntitySetName)" `
            -Quiet

        try {
            if ($UsageDateProperty) {
                $UsageFilter = "$UsageDateProperty ge $PastDateUTC"

                $ApplicationUsageTables[$ApplicationUsageEntity.EntitySetName] = Invoke-ODataPagedQuery -Uri (
                    New-ODataEntityUri `
                        -BaseUrl $BaseUrl `
                        -EntitySetName $ApplicationUsageEntity.EntitySetName `
                        -Filter $UsageFilter
                )
            }
            else {
                $ApplicationUsageTables[$ApplicationUsageEntity.EntitySetName] = Invoke-ODataPagedQuery -Uri (
                    New-ODataEntityUri `
                        -BaseUrl $BaseUrl `
                        -EntitySetName $ApplicationUsageEntity.EntitySetName
                )
            }
        }
        catch {
            Write-Warning "Application usage extraction failed for '$($ApplicationUsageEntity.EntitySetName)'. $($_.Exception.Message)"
        }
    }
}
catch {
    Write-Error "CRITICAL: OData discovery or extraction failed. $($_.Exception.Message)"

    if ($script:LastODataUri) {
        Write-Error "Last attempted OData URI: $script:LastODataUri"
    }

    try { Stop-Transcript | Out-Null } catch {}
    exit 1
}

if (-not $RawSessions -or $RawSessions.Count -eq 0) {
    Write-Warning "No session records were located inside the $LookbackDays day lookup window."
    try { Stop-Transcript | Out-Null } catch {}
    exit 0
}

