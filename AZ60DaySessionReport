#==============================================================================#============================================================================ and CSV export
# Output Target: C:\Temp\Reports\
#
# Output Columns:
#   User, Delivery Group, Published Application, Published Desktop,
#   VDA Host, CPU, MEM, Logon Time
#
# Design:
#   - Metadata-driven Citrix Monitor OData discovery
#   - CVAD version-agnostic where practical
#   - No hard-coded Monitor database/schema table names
#   - No per-session OData navigation calls
#   - Broker SDK fallback for Delivery Group, machine kind, app and desktop entitlement
#   - Published Application and Published Desktop resolved independently
#   - Controlled desktop fallback to prevent app-only users inheriting desktops
#   - HTML filter for last 1, 7, 30, 60 days, and all loaded data
# Author: Miral Mehta
# HTML Enhancements: Google AI
#==============================================================================

[CmdletBinding()]
param(
    [int]$LookbackDays = 60,
    [string]$ControllerAddress = "localhost",
    [string]$TargetDirectory = "C:\Temp\Reports",
    [switch]$PreferHttp,
    [switch]$EnableApplicationDiagnostics
)

$ErrorActionPreference = "Stop"
$script:LastODataUri = $null

#------------------------------------------------------------------------------
# Initialisation
#------------------------------------------------------------------------------

$ArchiveDirectory = Join-Path $TargetDirectory "Archive"

foreach ($Directory in @($TargetDirectory, $ArchiveDirectory)) {
    if (-not (Test-Path $Directory)) {
        New-Item -ItemType Directory -Path $Directory -Force | Out-Null
    }
}

$TimestampToken = (Get-Date).ToString("yyyyMMdd_HHmmss")

$OutputHtmlFile = Join-Path $TargetDirectory "Citrix_Director_Historical_Dashboard_$TimestampToken.html"
$OutputCsvFile  = Join-Path $TargetDirectory "Citrix_Director_Historical_Dashboard_$TimestampToken.csv"
$LogFile        = Join-Path $TargetDirectory "Citrix_Dashboard_Compiler_$TimestampToken.log"

try {
    Start-Transcript -Path $LogFile -Force | Out-Null
}
catch {
    Write-Warning "Unable to start transcript logging. Continuing without transcript. $($_.Exception.Message)"
}

