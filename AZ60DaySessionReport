function Test-IsClearlyAppOnlyUser {
    param(
        [AllowNull()]
        [string]$SessionUserName,

        [AllowNull()]
        [string]$SessionUserRef,

        [Parameter(Mandatory)]
        [object]$BrokerFallbackMaps
    )

    $NormalisedSessionUserName = Convert-ToNormalisedReferenceString -Value $SessionUserName
    $NormalisedSessionUserRef  = Convert-ToNormalisedReferenceString -Value $SessionUserRef

    $HasUserApp = $false
    $HasUserDesktop = $false

    foreach ($UserKey in @($NormalisedSessionUserName, $NormalisedSessionUserRef)) {
        if ([System.String]::IsNullOrWhiteSpace($UserKey)) {
            continue
        }

        if ($BrokerFallbackMaps.AppsByUserName.ContainsKey($UserKey)) {
            if ($BrokerFallbackMaps.AppsByUserName[$UserKey].Count -gt 0) {
                $HasUserApp = $true
            }
        }

        if ($BrokerFallbackMaps.DesktopsByUserName.ContainsKey($UserKey)) {
            if ($BrokerFallbackMaps.DesktopsByUserName[$UserKey].Count -gt 0) {
                $HasUserDesktop = $true
            }
        }
    }

    return ($HasUserApp -and -not $HasUserDesktop)
}

