function Get-MetricEntityScore {
    param(
        [Parameter(Mandatory)]
        [object]$MetricEntity
    )

    $Name = [string]$MetricEntity.EntitySetName
    $Props = @($MetricEntity.Properties)
    $Score = 0

    if ($Name -match '^ResourceUtilizationSummary$') { $Score += 100 }
    elseif ($Name -match '^ResourceUtilization$')    { $Score += 90 }
    elseif ($Name -match '^LoadIndexes$')            { $Score += 60 }
    elseif ($Name -match 'Desktop|Server')           { $Score += 50 }

    if ($Name -match 'User')    { $Score -= 40 }
    if ($Name -match 'Process') { $Score -= 50 }

    foreach ($PropertyName in @("AvgPercentCpu", "AveragePercentCpu", "AvgUsedMemory", "AverageUsedMemory")) {
        if ($Props -contains $PropertyName) {
            $Score += 25
        }
    }

    if ($Props -contains "Cpu")    { $Score += 10 }
    if ($Props -contains "Memory") { $Score += 10 }

    foreach ($PropertyName in @("MachineId", "MachineGuid", "MachineKey")) {
        if ($Props -contains $PropertyName) {
            $Score += 20
        }
    }

    return $Score
}

function Get-NormalizedMetricsMap {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [object[]]$MetricsTable,

        [Parameter(Mandatory)]
        [string[]]$MetricProperties,

        [Parameter(Mandatory)]
        [System.Collections.IDictionary]$MachineNameLookupIndex,

        [int]$SourceScore = 0,

        [string]$SourceEntityName = ""
    )

    $ResultingMap = @{}

    if (-not $MetricsTable -or $MetricsTable.Count -eq 0) {
        return $ResultingMap
    }

    $MachineReferenceProperty = Resolve-FirstAvailableProperty `
        -AvailableProperties $MetricProperties `
        -PreferredNames @("MachineId", "MachineKey", "MachineGuid", "MachineUUID", "MachineUid", "MachineUId", "Guid", "Id") `
        -Purpose "Metric machine reference" `
        -Quiet

    $MachineNameMetricProperty = Resolve-FirstAvailableProperty `
        -AvailableProperties $MetricProperties `
        -PreferredNames @("MachineName", "HostedMachineName", "Name", "DnsName", "DNSName") `
        -Purpose "Metric machine name" `
        -Quiet

    $CpuProperty = Resolve-FirstAvailableProperty `
        -AvailableProperties $MetricProperties `
        -PreferredNames @("AvgPercentCpu", "AveragePercentCpu", "PeakPercentCpu", "AvgCpuUtil", "CpuPercent", "CpuPercentage", "Cpu", "ProcessorUsage") `
        -Purpose "Metric CPU" `
        -Quiet

    $MemoryProperty = Resolve-FirstAvailableProperty `
        -AvailableProperties $MetricProperties `
        -PreferredNames @("AvgUsedMemory", "AverageUsedMemory", "PeakPercentMemory", "AvgMemoryUtil", "MemoryPercent", "MemoryPercentage", "Memory", "UsedMemory") `
        -Purpose "Metric memory" `
        -Quiet

    if (-not $MachineReferenceProperty -and -not $MachineNameMetricProperty) {
        return $ResultingMap
    }

    $RowsWithKey = foreach ($Row in $MetricsTable) {
        $ResolvedKey = $null

        if ($MachineReferenceProperty -and $null -ne $Row.$MachineReferenceProperty) {
            $MachineRef = Convert-ToNormalisedReferenceString -Value $Row.$MachineReferenceProperty

            if ($MachineRef -and $MachineNameLookupIndex.ContainsKey($MachineRef)) {
                $ResolvedKey = $MachineNameLookupIndex[$MachineRef]
            }
        }

        if (-not $ResolvedKey -and $MachineNameMetricProperty -and $null -ne $Row.$MachineNameMetricProperty) {
            $ResolvedKey = Get-ShortMachineName -MachineName $Row.$MachineNameMetricProperty
        }

        if ($ResolvedKey) {
            [PSCustomObject]@{
                MachineName = $ResolvedKey
                Row         = $Row
            }
        }
    }

    $GroupedMetrics = $RowsWithKey | Group-Object -Property MachineName

    foreach ($Group in $GroupedMetrics) {
        $CpuList = [System.Collections.Generic.List[double]]::new()
        $MemList = [System.Collections.Generic.List[double]]::new()

        foreach ($WrappedRow in $Group.Group) {
            $Row = $WrappedRow.Row

            if ($CpuProperty -and $null -ne $Row.$CpuProperty) {
                [void]$CpuList.Add([double]$Row.$CpuProperty)
            }

            if ($MemoryProperty -and $null -ne $Row.$MemoryProperty) {
                [void]$MemList.Add([double]$Row.$MemoryProperty)
            }
        }

        $AvgCpu = if ($CpuList.Count -gt 0) {
            ($CpuList | Measure-Object -Average).Average
        }
        else {
            $null
        }

        $AvgMem = if ($MemList.Count -gt 0) {
            ($MemList | Measure-Object -Average).Average
        }
        else {
            $null
        }

        $ResultingMap[$Group.Name] = [PSCustomObject]@{
            Cpu            = $AvgCpu
            Mem            = $AvgMem
            CpuProperty    = $CpuProperty
            MemoryProperty = $MemoryProperty
            SourceScore    = $SourceScore
            SourceEntity   = $SourceEntityName
        }
    }

    return $ResultingMap
}

