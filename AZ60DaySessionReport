function Invoke-BrokerCommandSafely {
    param(
        [Parameter(Mandatory)]
        [string]$CommandName
    )

    if (-not (Get-Command $CommandName -ErrorAction SilentlyContinue)) {
        return @()
    }

    try {
        return @(& $CommandName -MaxRecordCount 100000 -ErrorAction Stop)
    }
    catch {
        try {
            return @(& $CommandName -ErrorAction Stop)
        }
        catch {
            Write-Warning "Unable to run $CommandName. $($_.Exception.Message)"
            return @()
        }
    }
}

function Get-BrokerInventoryFallbackMaps {
    [CmdletBinding()]
    param()

    $Maps = [PSCustomObject]@{
        GroupNameByUid              = @{}
        GroupUidByName              = @{}
        MachineGroupNameByCleanName = @{}
        MachineGroupUidByCleanName  = @{}
        MachineKindByCleanName      = @{}
        AppsByGroupUid              = @{}
        AppsByGroupName             = @{}
        AppsByUserName              = @{}
        DesktopsByUserName          = @{}
        DesktopsByGroupUid          = @{}
        DesktopsByGroupName         = @{}
    }

    Import-CitrixBrokerSnapInIfAvailable

    if (-not (Get-Command Get-BrokerMachine -ErrorAction SilentlyContinue)) {
        Write-Warning "Citrix Broker SDK is not available. Broker fallback maps cannot be built."
        return $Maps
    }

    $BrokerDesktopGroups = Invoke-BrokerCommandSafely -CommandName "Get-BrokerDesktopGroup"

    foreach ($DesktopGroup in $BrokerDesktopGroups) {
        $GroupName = Get-ObjectPropertyValue `
            -InputObject $DesktopGroup `
            -PropertyNames @("Name", "DesktopGroupName", "DeliveryGroupName", "PublishedName")

        $GroupUid = Get-ObjectPropertyValue `
            -InputObject $DesktopGroup `
            -PropertyNames @("Uid", "UId", "Id", "DesktopGroupUid", "DesktopGroupUId", "DesktopGroupId")

        $GroupUidKey = Convert-ToNormalisedReferenceString -Value $GroupUid

        if ($GroupName -and $GroupUidKey) {
            $Maps.GroupNameByUid[$GroupUidKey] = [string]$GroupName
            $Maps.GroupUidByName[[string]$GroupName] = $GroupUidKey
        }
    }

    $BrokerMachines = Invoke-BrokerCommandSafely -CommandName "Get-BrokerMachine"

    foreach ($Machine in $BrokerMachines) {
        $MachineNames = [System.Collections.Generic.List[string]]::new()

        foreach ($NameProperty in @("MachineName", "DNSName", "DnsName", "HostedMachineName", "AgentName", "Name")) {
            if ($Machine.PSObject.Properties.Name -contains $NameProperty -and $Machine.$NameProperty) {
                $CleanName = Get-ShortMachineName -MachineName $Machine.$NameProperty

                if (-not [System.String]::IsNullOrWhiteSpace($CleanName)) {
                    [void]$MachineNames.Add($CleanName)
                }
            }
        }

        $MachineNames = @($MachineNames | Sort-Object -Unique)

        if ($MachineNames.Count -eq 0) {
            continue
        }

        $GroupName = Get-ObjectPropertyValue `
            -InputObject $Machine `
            -PropertyNames @("DesktopGroupName", "DeliveryGroupName", "GroupName")

        $GroupUid = Get-ObjectPropertyValue `
            -InputObject $Machine `
            -PropertyNames @(
                "DesktopGroupUid",
                "DesktopGroupUId",
                "DesktopGroupId",
                "DeliveryGroupId",
                "DeliveryGroupUid",
                "GroupId",
                "GroupUid"
            )

        $GroupUidKey = Convert-ToNormalisedReferenceString -Value $GroupUid

        if ((-not $GroupName) -and $GroupUidKey -and $Maps.GroupNameByUid.ContainsKey($GroupUidKey)) {
            $GroupName = $Maps.GroupNameByUid[$GroupUidKey]
        }

        $MachineKind = Get-ObjectPropertyValue `
            -InputObject $Machine `
            -PropertyNames @(
                "SessionSupport",
                "DesktopKind",
                "AllocationType",
                "MachineRole",
                "MachineType",
                "OSType",
                "OSName",
                "OperatingSystem"
            )

        foreach ($CleanName in $MachineNames) {
            if ($GroupName) {
                $Maps.MachineGroupNameByCleanName[$CleanName] = [string]$GroupName
            }

            if ($GroupUidKey) {
                $Maps.MachineGroupUidByCleanName[$CleanName] = $GroupUidKey
            }

            if ($MachineKind) {
                $Maps.MachineKindByCleanName[$CleanName] = [string]$MachineKind
            }
        }
    }

    $BrokerApplications = Invoke-BrokerCommandSafely -CommandName "Get-BrokerApplication"

    foreach ($Application in $BrokerApplications) {
        $ApplicationName = Get-ObjectPropertyValue `
            -InputObject $Application `
            -PropertyNames @("PublishedName", "ApplicationName", "Name", "BrowserName", "DisplayName")

        if (-not $ApplicationName) {
            continue
        }

        $ApplicationName = [string]$ApplicationName

        $AssociatedGroupValues = [System.Collections.Generic.List[string]]::new()

        foreach ($GroupProperty in @(
            "AssociatedDesktopGroupUids",
            "AssociatedDesktopGroupIds",
            "DesktopGroupUids",
            "DesktopGroupIds",
            "DesktopGroupUid",
            "DesktopGroupUId",
            "DesktopGroupId",
            "DeliveryGroupUid",
            "DeliveryGroupId",
            "GroupUid",
            "GroupId"
        )) {
            if ($Application.PSObject.Properties.Name -contains $GroupProperty) {
                foreach ($Value in (Get-NormalisedReferenceValuesFromValue -Value $Application.$GroupProperty)) {
                    [void]$AssociatedGroupValues.Add($Value)
                }
            }
        }

        $AssociatedGroupValues = @($AssociatedGroupValues | Sort-Object -Unique)

        foreach ($GroupUidKey in $AssociatedGroupValues) {
            Add-MapListValue -Map $Maps.AppsByGroupUid -Key $GroupUidKey -Value $ApplicationName

            if ($Maps.GroupNameByUid.ContainsKey($GroupUidKey)) {
                $GroupName = $Maps.GroupNameByUid[$GroupUidKey]
                Add-MapListValue -Map $Maps.AppsByGroupName -Key $GroupName -Value $ApplicationName
            }
        }

        $AssociatedUserValues = [System.Collections.Generic.List[string]]::new()

        foreach ($UserProperty in @(
            "AssociatedUserNames",
            "AssociatedUsers",
            "UserNames",
            "Users",
            "IncludedUsers",
            "IncludedUserNames",
            "AccountNames",
            "Accounts",
            "AllowedUsers",
            "AllowedUserNames"
        )) {
            if ($Application.PSObject.Properties.Name -contains $UserProperty) {
                foreach ($Value in (Get-NormalisedReferenceValuesFromValue -Value $Application.$UserProperty)) {
                    [void]$AssociatedUserValues.Add($Value)
                }
            }
        }

        $AssociatedUserValues = @($AssociatedUserValues | Sort-Object -Unique)

        foreach ($UserKey in $AssociatedUserValues) {
            Add-MapListValue -Map $Maps.AppsByUserName -Key $UserKey -Value $ApplicationName
        }
    }

    $BrokerEntitlementRules = Invoke-BrokerCommandSafely -CommandName "Get-BrokerEntitlementPolicyRule"

    foreach ($Rule in $BrokerEntitlementRules) {
        $RuleEnabled = Get-ObjectPropertyValue `
            -InputObject $Rule `
            -PropertyNames @("Enabled")

        if ($null -ne $RuleEnabled -and [string]$RuleEnabled -match 'False') {
            continue
        }

        $DesktopName = Get-ObjectPropertyValue `
            -InputObject $Rule `
            -PropertyNames @("PublishedName", "DesktopName", "Name", "IncludedDesktopName", "EntitlementName")

        $GroupUid = Get-ObjectPropertyValue `
            -InputObject $Rule `
            -PropertyNames @(
                "DesktopGroupUid",
                "DesktopGroupUId",
                "DesktopGroupId",
                "DeliveryGroupUid",
                "DeliveryGroupId",
                "GroupUid",
                "GroupId"
            )

        $GroupUidKey = Convert-ToNormalisedReferenceString -Value $GroupUid

        if (-not $DesktopName -and $GroupUidKey -and $Maps.GroupNameByUid.ContainsKey($GroupUidKey)) {
            $DesktopName = $Maps.GroupNameByUid[$GroupUidKey]
        }

        if (-not $DesktopName) {
            continue
        }

        $DesktopName = [string]$DesktopName

        if ($GroupUidKey) {
            Add-MapListValue -Map $Maps.DesktopsByGroupUid -Key $GroupUidKey -Value $DesktopName

            if ($Maps.GroupNameByUid.ContainsKey($GroupUidKey)) {
                $GroupName = $Maps.GroupNameByUid[$GroupUidKey]
                Add-MapListValue -Map $Maps.DesktopsByGroupName -Key $GroupName -Value $DesktopName
            }
        }

        $IncludedUserValues = [System.Collections.Generic.List[string]]::new()

        foreach ($UserProperty in @(
            "IncludedUsers",
            "IncludedUserNames",
            "AllowedUsers",
            "AllowedUserNames",
            "AssociatedUsers",
            "AssociatedUserNames",
            "UserNames",
            "Users",
            "Accounts",
            "AccountNames"
        )) {
            if ($Rule.PSObject.Properties.Name -contains $UserProperty) {
                foreach ($Value in (Get-NormalisedReferenceValuesFromValue -Value $Rule.$UserProperty)) {
                    [void]$IncludedUserValues.Add($Value)
                }
            }
        }

        $IncludedUserValues = @($IncludedUserValues | Sort-Object -Unique)

        foreach ($UserKey in $IncludedUserValues) {
            Add-MapListValue -Map $Maps.DesktopsByUserName -Key $UserKey -Value $DesktopName
        }
    }

    Write-Host "Broker fallback group entries         : $($Maps.GroupNameByUid.Count)" -ForegroundColor DarkCyan
    Write-Host "Broker fallback machine group entries : $($Maps.MachineGroupNameByCleanName.Count)" -ForegroundColor DarkCyan
    Write-Host "Broker fallback app group entries     : $($Maps.AppsByGroupUid.Count)" -ForegroundColor DarkCyan
    Write-Host "Broker fallback user app entries      : $($Maps.AppsByUserName.Count)" -ForegroundColor DarkCyan
    Write-Host "Broker fallback user desktop entries  : $($Maps.DesktopsByUserName.Count)" -ForegroundColor DarkCyan
    Write-Host "Broker fallback group desktop entries : $($Maps.DesktopsByGroupUid.Count)" -ForegroundColor DarkCyan

    return $Maps
}

function Resolve-ApplicationFromBrokerUserFallback {
    param(
        [AllowNull()]
        [string]$SessionUserName,

        [AllowNull()]
        [string]$SessionUserRef,

        [Parameter(Mandatory)]
        [object]$BrokerFallbackMaps
    )

    $CandidateApps = [System.Collections.Generic.List[string]]::new()

    $NormalisedSessionUserName = Convert-ToNormalisedReferenceString -Value $SessionUserName
    $NormalisedSessionUserRef  = Convert-ToNormalisedReferenceString -Value $SessionUserRef

    if ($BrokerFallbackMaps.PSObject.Properties.Name -contains "AppsByUserName") {
        if ($NormalisedSessionUserName -and $BrokerFallbackMaps.AppsByUserName.ContainsKey($NormalisedSessionUserName)) {
            foreach ($App in $BrokerFallbackMaps.AppsByUserName[$NormalisedSessionUserName]) {
                [void]$CandidateApps.Add([string]$App)
            }
        }

        if ($NormalisedSessionUserRef -and $BrokerFallbackMaps.AppsByUserName.ContainsKey($NormalisedSessionUserRef)) {
            foreach ($App in $BrokerFallbackMaps.AppsByUserName[$NormalisedSessionUserRef]) {
                [void]$CandidateApps.Add([string]$App)
            }
        }
    }

    $DistinctApps = @($CandidateApps | Sort-Object -Unique)

    if ($DistinctApps.Count -eq 1) {
        return $DistinctApps[0]
    }

    return $null
}

