function Resolve-ApplicationFromEvidence {
    param(
        [Parameter(Mandatory)]
        [string[]]$SessionRefs,

        [AllowNull()]
        [string]$SessionUserRef,

        [AllowNull()]
        [string]$SessionUserName,

        [AllowNull()]
        [string]$SessionMachineRef,

        [AllowNull()]
        [string]$CleanVdaHostName,

        [AllowNull()]
        [object]$SessionStartTime,

        [Parameter(Mandatory)]
        [object[]]$ApplicationEvidence
    )

    foreach ($SessionRef in $SessionRefs) {
        $ExactMatches = @(
            $ApplicationEvidence | Where-Object {
                $_.SessionRefs -contains $SessionRef
            }
        )

        if ($ExactMatches.Count -gt 0) {
            return (($ExactMatches.AppName | Sort-Object -Unique) -join ", ")
        }
    }

    $NormalisedSessionUserName = Convert-ToNormalisedReferenceString -Value $SessionUserName

    $CandidateMatches = foreach ($Evidence in $ApplicationEvidence) {
        $Score = 0

        if ($SessionUserRef -and $Evidence.UserRefs -contains $SessionUserRef) {
            $Score += 45
        }

        if ($NormalisedSessionUserName -and $Evidence.UserNames -contains $NormalisedSessionUserName) {
            $Score += 45
        }

        if ($SessionMachineRef -and $Evidence.MachineRefs -contains $SessionMachineRef) {
            $Score += 45
        }

        if ($CleanVdaHostName -and $Evidence.MachineNames) {
            foreach ($EvidenceMachineName in $Evidence.MachineNames) {
                if ((Get-ShortMachineName -MachineName $EvidenceMachineName) -eq $CleanVdaHostName) {
                    $Score += 45
                    break
                }
            }
        }

        if ($SessionStartTime -and $Evidence.EvidenceTime) {
            $Score += Get-SessionTimeWindowMatchScore `
                -SessionStart ([DateTime]$SessionStartTime) `
                -EvidenceTime ([DateTime]$Evidence.EvidenceTime)
        }

        if ($Score -ge 80) {
            [PSCustomObject]@{
                AppName = $Evidence.AppName
                Score   = $Score
                Time    = $Evidence.EvidenceTime
                Entity  = $Evidence.EntitySetName
            }
        }
    }

    $BestMatches = @(
        $CandidateMatches |
            Sort-Object Score -Descending |
            Select-Object -First 5
    )

    if ($BestMatches.Count -gt 0) {
        $TopScore = ($BestMatches | Select-Object -First 1).Score

        $TopApps = @(
            $BestMatches |
                Where-Object { $_.Score -eq $TopScore } |
                Select-Object -ExpandProperty AppName |
                Sort-Object -Unique
        )

        if ($TopApps.Count -gt 0) {
            return ($TopApps -join ", ")
        }
    }

    return $null
}

function Resolve-SingleApplicationFallback {
    param(
        [AllowNull()]
        [string]$SessionUserRef,

        [AllowNull()]
        [string]$SessionUserName,

        [Parameter(Mandatory)]
        [object[]]$ApplicationEvidence
    )

    $NormalisedSessionUserName = Convert-ToNormalisedReferenceString -Value $SessionUserName

    $UserMatches = @(
        $ApplicationEvidence | Where-Object {
            ($SessionUserRef -and $_.UserRefs -contains $SessionUserRef) -or
            ($NormalisedSessionUserName -and $_.UserNames -contains $NormalisedSessionUserName)
        }
    )

    if ($UserMatches.Count -gt 0) {
        $DistinctUserApps = @($UserMatches | Select-Object -ExpandProperty AppName -Unique)

        if ($DistinctUserApps.Count -eq 1) {
            return $DistinctUserApps[0]
        }
    }

    return $null
}

