$HtmlMiddle = @"
;
        let sessionData =
"@

$HtmlFooter = @"
;

        if (!Array.isArray(sessionData)) {
            sessionData = sessionData ? [sessionData] : [];
        }

        function escapeHtml(value) {
            if (value === null || value === undefined || value === '') {
                return '<span class="empty-cell">blank</span>';
            }

            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function rawCsvValue(value) {
            if (value === null || value === undefined) {
                return '';
            }

            return String(value).replace(/"/g, '""');
        }

        function renderSummary() {
            const panel = document.getElementById('summaryPanel');

            panel.innerHTML =
                '<strong>Discovered Monitor OData entity sets:</strong><br>' +
                'Users: <code>' + escapeHtml(discoverySummary.UserEntitySet) + '</code> | ' +
                'Machines: <code>' + escapeHtml(discoverySummary.MachineEntitySet) + '</code> | ' +
                'Delivery Groups: <code>' + escapeHtml(discoverySummary.DeliveryGroupEntitySet) + '</code> | ' +
                'Applications: <code>' + escapeHtml(discoverySummary.ApplicationEntitySet) + '</code> | ' +
                'Sessions: <code>' + escapeHtml(discoverySummary.SessionEntitySet) + '</code><br>' +
                'Application usage/evidence: <code>' + escapeHtml(discoverySummary.ApplicationUsageEntitySets) + '</code><br>' +
                'Metrics: <code>' + escapeHtml(discoverySummary.MetricEntitySets) + '</code><br>' +
                'CSV file written by PowerShell: <code>' + escapeHtml(discoverySummary.CsvOutput) + '</code>';
        }

        function getFilteredData() {
            const filter = document.getElementById('search').value.toLowerCase();
            const rangeValue = document.getElementById('rangeFilter').value;
            const now = Date.now();

            return sessionData.filter(row => {
                const textMatch = !filter || Object.keys(row).some(key => {
                    return String(row[key] || '').toLowerCase().includes(filter);
                });

                if (!textMatch) {
                    return false;
                }

                if (rangeValue === 'all') {
                    return true;
                }

                if (!row.LogonEpoch) {
                    return false;
                }

                const days = Number(rangeValue);
                const since = now - (days * 24 * 60 * 60 * 1000);

                return Number(row.LogonEpoch) >= since;
            });
        }

        function renderDashboard() {
            const data = getFilteredData();
            const groups = {};

            data.forEach(item => {
                const user = item.User || 'System Account / Unresolved';

                if (!groups[user]) {
                    groups[user] = [];
                }

                groups[user].push(item);
            });

            const caption = document.getElementById('viewCaption');
            const rangeText = document.getElementById('rangeFilter').selectedOptions[0].text;
            caption.textContent = 'Showing ' + data.length + ' session row(s) for ' + rangeText + '.';

            const container = document.getElementById('dashboard');
            container.innerHTML = '';

            const userNames = Object.keys(groups).sort();

            if (userNames.length === 0) {
                container.innerHTML = '<div class="summary-panel">No matching records found.</div>';
                return;
            }

            userNames.forEach(user => {
                const rows = groups[user];

                const userBox = document.createElement('div');
                userBox.className = 'user-container';

                let html = '';
                html += '<details class="user-dropdown">';
                html += '<summary>';
                html += '<span>User: ' + escapeHtml(user) + '</span>';
                html += '<span class="row-count-col">Total Sessions: ' + rows.length + '</span>';
                html += '<span class="arrow-col">▼</span>';
                html += '</summary>';
                html += '<div class="user-content">';
                html += '<div class="table-container">';
                html += '<table>';
                html += '<thead>';
                html += '<tr>';
                html += '<th>User</th>';
                html += '<th>Delivery Group</th>';
                html += '<th>Published Application</th>';
                html += '<th>Published Desktop</th>';
                html += '<th>VDA Host</th>';
                html += '<th>CPU</th>';
                html += '<th>MEM</th>';
                html += '<th>Logon Time</th>';
                html += '</tr>';
                html += '</thead>';
                html += '<tbody>';

                rows.forEach(row => {
                    html += '<tr>';
                    html += '<td>' + escapeHtml(row.User) + '</td>';
                    html += '<td><strong>' + escapeHtml(row['Delivery Group']) + '</strong></td>';
                    html += '<td>' + escapeHtml(row['Published Application']) + '</td>';
                    html += '<td>' + escapeHtml(row['Published Desktop']) + '</td>';
                    html += '<td><code>' + escapeHtml(row['VDA Host']) + '</code></td>';
                    html += '<td>' + escapeHtml(row.CPU) + '</td>';
                    html += '<td>' + escapeHtml(row.MEM) + '</td>';
                    html += '<td>' + escapeHtml(row['Logon Time']) + '</td>';
                    html += '</tr>';
                });

                html += '</tbody>';
                html += '</table>';
                html += '</div>';
                html += '</div>';
                html += '</details>';

                userBox.innerHTML = html;
                container.appendChild(userBox);
            });
        }

        function exportToCSV() {
            const data = getFilteredData();

            if (!data || data.length === 0) {
                alert('No data available to export.');
                return;
            }

            const headers = [
                'User',
                'Delivery Group',
                'Published Application',
                'Published Desktop',
                'VDA Host',
                'CPU',
                'MEM',
                'Logon Time'
            ];

            const csvRows = [headers.join(',')];

            data.forEach(row => {
                csvRows.push([
                    '"' + rawCsvValue(row.User) + '"',
                    '"' + rawCsvValue(row['Delivery Group']) + '"',
                    '"' + rawCsvValue(row['Published Application']) + '"',
                    '"' + rawCsvValue(row['Published Desktop']) + '"',
                    '"' + rawCsvValue(row['VDA Host']) + '"',
                    '"' + rawCsvValue(row.CPU) + '"',
                    '"' + rawCsvValue(row.MEM) + '"',
                    '"' + rawCsvValue(row['Logon Time']) + '"'
                ].join(','));
            });

            const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');

            link.href = URL.createObjectURL(blob);
            link.setAttribute('download', 'Citrix_Historical_Sessions_Filtered_View.csv');

            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        renderSummary();
        renderDashboard();
    </script>
</body>
