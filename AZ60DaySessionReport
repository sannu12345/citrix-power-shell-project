            -CandidateProperties @(
                "SessionId",
                "SessionKey",
                "SessionUid",
                "SessionUId",
                "SessionGuid",
                "SessionUUID",
                "ConnectionId",
                "ConnectionKey",
                "ConnectionUid",
                "ConnectionUId",
                "ConnectionGuid",
                "ConnectionUUID",
                "LogOnId",
                "LogonId",
                "LogOnKey",
