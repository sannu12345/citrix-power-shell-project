            }

            if (-not $SessionApplicationNameMap[$SessionRef].Contains([string]$ResolvedAppName)) {
                [void]$SessionApplicationNameMap[$SessionRef].Add([string]$ResolvedAppName)
            }
        }

        $EvidenceUserRefs = Get-RowReferenceValues `
            -InputObject $Row `
            -CandidateProperties @("UserId", "UserKey", "UserUid", "UserUId", "UserSid", "SID", "Sid")

        $EvidenceUserNames = Get-RowReferenceValues `
