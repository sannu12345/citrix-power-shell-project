# Generic Helpers
#------------------------------------------------------------------------------

function Write-Section {
    param(
        [Parameter(Mandatory)]
        [string]$Message
    )

    Write-Host ""
    Write-Host "=============================================================================="
    Write-Host $Message -ForegroundColor Cyan
    Write-Host "=============================================================================="
}

function Test-Blank {
    param(
        [AllowNull()]
        [object]$Value
    )

    return [System.String]::IsNullOrWhiteSpace([string]$Value)
}

function Import-CitrixBrokerSnapInIfAvailable {
    try {
        if (-not (Get-Command Get-BrokerController -ErrorAction SilentlyContinue)) {
            Add-PSSnapin Citrix.Broker.Admin.V2 -ErrorAction SilentlyContinue
        }
    }
    catch {
        Write-Verbose "Citrix Broker snap-in could not be loaded automatically. $($_.Exception.Message)"
    }
}

function Convert-ToNormalisedReferenceString {
    param(
        [AllowNull()]
        [object]$Value
    )

    if ($null -eq $Value) {
        return $null
    }

    $Text = [string]$Value

    if ([System.String]::IsNullOrWhiteSpace($Text)) {
        return $null
    }

    $Text = $Text.Trim()
    $Text = $Text.Trim("{", "}")

    if ([System.String]::IsNullOrWhiteSpace($Text)) {
        return $null
    }

    return $Text.ToLowerInvariant()
}

function Get-NormalisedReferenceValuesFromValue {
    param(
        [AllowNull()]
        [object]$Value
    )

    $Results = [System.Collections.Generic.List[string]]::new()

    if ($null -eq $Value) {
        return @()
    }

    if ($Value -is [System.Collections.IEnumerable] -and $Value -isnot [string]) {
        foreach ($Item in $Value) {
            $Normalised = Convert-ToNormalisedReferenceString -Value $Item

            if (-not [System.String]::IsNullOrWhiteSpace($Normalised)) {
                [void]$Results.Add($Normalised)
            }
        }
    }
    else {
        $Normalised = Convert-ToNormalisedReferenceString -Value $Value

        if (-not [System.String]::IsNullOrWhiteSpace($Normalised)) {
            [void]$Results.Add($Normalised)
        }
    }

    return @($Results | Sort-Object -Unique)
}

function Add-MapListValue {
    param(
        [Parameter(Mandatory)]
        [System.Collections.IDictionary]$Map,

        [Parameter(Mandatory)]
        [string]$Key,

        [Parameter(Mandatory)]
        [string]$Value
    )

    if ([System.String]::IsNullOrWhiteSpace($Key) -or [System.String]::IsNullOrWhiteSpace($Value)) {
        return
    }

    if (-not $Map.ContainsKey($Key)) {
        $Map[$Key] = [System.Collections.Generic.List[string]]::new()
    }

    if (-not $Map[$Key].Contains($Value)) {
        [void]$Map[$Key].Add($Value)
    }
}

function Get-ObjectPropertyValue {
    param(
        [Parameter(Mandatory)]
        [object]$InputObject,

        [Parameter(Mandatory)]
        [string[]]$PropertyNames
    )

    if ($null -eq $InputObject) {
        return $null
    }

    foreach ($PropertyName in $PropertyNames) {
        if ($InputObject.PSObject.Properties.Name -contains $PropertyName) {
            $Value = $InputObject.$PropertyName

            if ($null -ne $Value -and -not (Test-Blank $Value)) {
                return $Value
            }
        }
    }

    return $null
}

function Get-RowReferenceValues {
    param(
        [Parameter(Mandatory)]
        [object]$InputObject,

        [Parameter(Mandatory)]
        [string[]]$CandidateProperties
    )

    $Values = [System.Collections.Generic.List[string]]::new()

    if ($null -eq $InputObject) {
        return @()
    }

    foreach ($PropertyName in $CandidateProperties) {
        if ($InputObject.PSObject.Properties.Name -contains $PropertyName) {
            foreach ($Value in (Get-NormalisedReferenceValuesFromValue -Value $InputObject.$PropertyName)) {
                [void]$Values.Add($Value)
            }
        }
    }

    return @($Values | Sort-Object -Unique)
}

function Convert-ToNullableDateTime {
    param(
        [AllowNull()]
        [object]$Value
    )

    if ($null -eq $Value) {
        return $null
    }

    try {
        return [DateTime]$Value
    }
    catch {
        return $null
    }
}

function Get-FirstDatePropertyValue {
    param(
        [Parameter(Mandatory)]
        [object]$InputObject,

        [Parameter(Mandatory)]
        [string[]]$PropertyNames
    )

    if ($null -eq $InputObject) {
        return $null
    }

    foreach ($PropertyName in $PropertyNames) {
        if ($InputObject.PSObject.Properties.Name -contains $PropertyName) {
            $DateValue = Convert-ToNullableDateTime -Value $InputObject.$PropertyName

            if ($null -ne $DateValue) {
                return $DateValue
            }
        }
    }

    return $null
}

function Get-ShortMachineName {
    param(
        [AllowNull()]
        [object]$MachineName
    )

    if ($null -eq $MachineName) {
        return ""
    }

    $RawName = [string]$MachineName

    if ([System.String]::IsNullOrWhiteSpace($RawName)) {
        return ""
    }

    $Parts = $RawName -split '\\'
    return ([string]$Parts[-1]).Trim().ToLowerInvariant()
}

function Format-CpuMetric {
    param(
        [Nullable[double]]$Value
    )

    if ($null -eq $Value -or $Value -lt 0) {
        return "No Data"
    }

    return "$([System.Math]::Round($Value, 0))%"
}

function Format-MemoryMetric {
    param(
        [Nullable[double]]$Value,

        [AllowNull()]
        [string]$SourceProperty
    )

    if ($null -eq $Value -or $Value -le 0) {
        return "No Data"
    }

    if ($SourceProperty -and $SourceProperty -match 'Percent|Percentage|Util|Load') {
        return "$([System.Math]::Round($Value, 0))% Load"
    }

    if ($Value -gt 131072) {
        return "{0:N0} MB" -f ($Value / 1MB)
    }

    return "{0:N0} MB" -f $Value
}

function Test-IsDesktopSession {
    param(
        [AllowNull()]
        [object]$SessionTypeValue
    )

    if ($null -eq $SessionTypeValue) {
        return $false
    }

    $SessionTypeText = ([string]$SessionTypeValue).Trim()

    switch -Regex ($SessionTypeText) {
        '^(1)$'               { return $true }
        'Desktop'             { return $true }
        'PublishedDesktop'    { return $true }
        'HostedSharedDesktop' { return $true }
        'VDI'                 { return $true }
        default               { return $false }
    }
}

function Test-IsApplicationSession {
    param(
        [AllowNull()]
        [object]$SessionTypeValue
    )

    if ($null -eq $SessionTypeValue) {
        return $false
    }

    $SessionTypeText = ([string]$SessionTypeValue).Trim()

    switch -Regex ($SessionTypeText) {
        '^(2)$'                { return $true }
        'Application'          { return $true }
        'PublishedApplication' { return $true }
        'App'                  { return $true }
        default                { return $false }
    }
}

function Get-SessionCandidateReferenceValues {
    param(
        [Parameter(Mandatory)]
        [object]$Session
    )

    $CandidateProperties = [System.Collections.Generic.List[string]]::new()

    foreach ($PropertyName in @(
        "Id",
        "Key",
        "Uid",
        "UId",
        "Guid",
        "UUID",
        "SessionId",
        "SessionKey",
        "SessionUid",
        "SessionUId",
        "SessionGuid",
        "SessionUUID",
        "ConnectionId",
        "ConnectionKey",
        "ConnectionUid",
        "ConnectionUId",
        "ConnectionGuid",
        "ConnectionUUID",
        "LogOnId",
        "LogonId",
        "LogOnKey",
        "LogonKey"
    )) {
        [void]$CandidateProperties.Add($PropertyName)
    }

    foreach ($Property in $Session.PSObject.Properties) {
        if ($Property.Name -match 'Session|Connection|Logon|LogOn|Key|Uid|UId|Guid|UUID|^Id$') {
            [void]$CandidateProperties.Add($Property.Name)
        }
    }

    return Get-RowReferenceValues `
        -InputObject $Session `
        -CandidateProperties @($CandidateProperties | Sort-Object -Unique)
}

function Get-SessionTimeWindowMatchScore {
    param(
        [Parameter(Mandatory)]
        [DateTime]$SessionStart,

        [Parameter(Mandatory)]
        [DateTime]$EvidenceTime
    )

    $MinutesDifference = [System.Math]::Abs(
        ($SessionStart.ToUniversalTime() - $EvidenceTime.ToUniversalTime()).TotalMinutes
    )

    if ($MinutesDifference -le 2)  { return 100 }
    if ($MinutesDifference -le 5)  { return 80 }
    if ($MinutesDifference -le 15) { return 60 }
    if ($MinutesDifference -le 60) { return 30 }

    return 0
}

function Test-MachineLooksLikeDesktop {
    param(
        [AllowNull()]
        [string]$CleanMachineName,

        [AllowNull()]
        [string]$MachineKindText
    )

    if (-not (Test-Blank $MachineKindText)) {
        if ($MachineKindText -match 'Desktop|VDI|SingleSession|Single-session|Private|Assigned') {
            return $true
        }

        if ($MachineKindText -match 'Server|MultiSession|Multi-session|Shared|App') {
            return $false
        }
    }

    if ($CleanMachineName -and $CleanMachineName -match 'vdi|win10|win11|desktop') {
        return $true
    }

    return $false
}

