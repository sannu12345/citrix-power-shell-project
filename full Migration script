<#
.SYNOPSIS
    Export Citrix CVAD Site configuration to structured XML.

.DESCRIPTION
    Exports selected CVAD site configuration elements to a custom XML file
    and exports published application icon data to a resources folder.

    Target output:
        C:\Temp\Reports\ctx_export.xml
        C:\Temp\Reports\resources\

    Exported elements:
        - Site Properties
        - Tags
        - Administrators, Roles and Scopes
        - Machine Catalogs
        - Provisioning Schemes
        - Identity Pools
        - Delivery Groups
        - Power Management Rules
        - Reboot Schedules
        - Published Applications
        - Published Application Icons
        - File Type Associations
        - Citrix Policies

.NOTES
    Author: Miral Mehta / Framework Skeleton
    Target: CVAD 1912 LTSR through current releases where compatible SDK cmdlets exist.
    Output: Custom CLIXML object model, not native Citrix ACT YAML.

    This is an export framework skeleton. Some environments may require local
    extension depending on:
        - MCS / PVS usage
        - Citrix Cloud vs on-prem
        - SDK version
        - Policy set model
        - Application Group usage
        - Multi-zone topology

Author: M Mehta with help from Co-Pilot
#>

[CmdletBinding()]
param(
    [Parameter(Mandatory = $false)]
    [string]$AdminAddress = "localhost",

    [Parameter(Mandatory = $false)]
    [string]$OutputFolder = "C:\Temp\Reports",

    [Parameter(Mandatory = $false)]
    [string]$OutputXmlName = "ctx_export.xml",

    [Parameter(Mandatory = $false)]
    [string]$ResourcesFolderName = "resources",

    [Parameter(Mandatory = $false)]
    [switch]$IncludeNativeConfigXml,

    [Parameter(Mandatory = $false)]
    [switch]$IncludePolicyBinaryExport,

    [Parameter(Mandatory = $false)]
    [switch]$VerboseLogging
)

# =============================================================================
# 0. Initialisation
# =============================================================================

Set-StrictMode -Version Latest
$ErrorActionPreference = "Stop"

$Script:OutputXmlPath     = Join-Path $OutputFolder $OutputXmlName
$Script:ResourcesFolder   = Join-Path $OutputFolder $ResourcesFolderName
$Script:NativeConfigPath  = Join-Path $OutputFolder "ctx_native_config.xml"
$schedules = $null

function Write-Log {
    param(
        [string]$Message,
        [ValidateSet("Info", "Warning", "Error", "Success", "Debug")]
        [string]$Level = "Info"
    )

    $colour = switch ($Level) {
        "Info"    { "Cyan" }
        "Warning" { "Yellow" }
        "Error"   { "Red" }
        "Success" { "Green" }
        "Debug"   { "DarkGray" }
    }

    if ($Level -ne "Debug" -or $VerboseLogging) {
        Write-Host "[$Level] $Message" -ForegroundColor $colour
    }
}

function Ensure-Folder {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Path
    )

    if (-not (Test-Path -LiteralPath $Path)) {
        [void](New-Item -ItemType Directory -Path $Path -Force)
    }
}

function Import-CitrixSdk {
    <#
        Loads Citrix snap-ins/modules in a tolerant way.
        Different CVAD versions may expose snap-ins/modules differently.
    #>

    Write-Log "Loading Citrix PowerShell SDK..." "Info"

    try {
        Add-PSSnapin Citrix* -ErrorAction SilentlyContinue
    }
    catch {
        Write-Log "Citrix snap-ins were not loaded via Add-PSSnapin. Continuing to module check." "Debug"
    }

    try {
        Import-Module Citrix.* -ErrorAction SilentlyContinue
    }
    catch {
        Write-Log "Citrix modules were not loaded via Import-Module. Continuing." "Debug"
    }

    $requiredCmdlets = @(
        "Get-BrokerSite",
        "Get-BrokerApplication",
        "Get-BrokerDesktopGroup",
        "Get-BrokerCatalog"
    )

    foreach ($cmdlet in $requiredCmdlets) {
        if (-not (Get-Command $cmdlet -ErrorAction SilentlyContinue)) {
            throw "Required Citrix SDK cmdlet not found: $cmdlet. Install the Citrix PowerShell SDK / Studio components."
        }
    }

    Write-Log "Citrix PowerShell SDK loaded successfully." "Success"
}

function Get-SafeProperty {
    <#
        Defensive property accessor to avoid breaking across CVAD versions.
    #>
    param(
        [Parameter(Mandatory = $true)]
        [object]$InputObject,

        [Parameter(Mandatory = $true)]
        [string]$PropertyName,

        [Parameter(Mandatory = $false)]
        [object]$DefaultValue = $null
    )

    if ($null -eq $InputObject) {
        return $DefaultValue
    }

    $property = $InputObject.PSObject.Properties[$PropertyName]

    if ($null -eq $property) {
        return $DefaultValue
    }

    return $property.Value
}

function Convert-ToExportSafeObject {
    <#
        Converts a PowerShell object into a simpler property bag.
        This avoids serialising overly complex SDK object internals.
    #>
    param(
        [Parameter(Mandatory = $true)]
        [object]$InputObject,

        [Parameter(Mandatory = $true)]
        [string[]]$PropertyNames
    )

    $hash = [ordered]@{}

    foreach ($propertyName in $PropertyNames) {
        $hash[$propertyName] = Get-SafeProperty -InputObject $InputObject -PropertyName $propertyName
    }

    [pscustomobject]$hash
}

function Convert-ToSafeFileName {
    param(
        [Parameter(Mandatory = $true)]
        [string]$Name
    )

    $invalidChars = [IO.Path]::GetInvalidFileNameChars()
    $safeName = $Name

    foreach ($char in $invalidChars) {
        $safeName = $safeName.Replace($char, "_")
    }

    if ([string]::IsNullOrWhiteSpace($safeName)) {
        $safeName = [guid]::NewGuid().ToString()
    }

    return $safeName
}

