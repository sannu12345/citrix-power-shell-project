function Export-CtxRebootSchedules {
    param(
        [string]$AdminAddress
    )

    Write-Log "Collecting reboot schedules..." "Info"

    # Prefer V2 cmdlet
    if (Get-Command Get-BrokerRebootScheduleV2 -ErrorAction SilentlyContinue) {

        $schedules = Get-BrokerRebootScheduleV2 `
            -AdminAddress $AdminAddress `
            -MaxRecordCount 2147483647

        $results = foreach ($schedule in $schedules) {

            Convert-ToExportSafeObject `
                -InputObject $schedule `
                -PropertyNames @(
                    "Name",
                    "Uid",
                    "DesktopGroupName",
                    "DesktopGroupUid",
                    "Enabled",
                    "Frequency",
                    "StartTime",
                    "RebootDuration",
                    "WarningDuration",
                    "WarningMessage",
                    "WarningRepeatInterval",
                    "RestrictToTag"
                )
        }

        return $results
    }

    # Fall back to legacy cmdlet
    if (Get-Command Get-BrokerRebootSchedule -ErrorAction SilentlyContinue) {

        Write-Log "Using legacy Get-BrokerRebootSchedule cmdlet." "Debug"

        $legacySchedules = Get-BrokerRebootSchedule `
            -AdminAddress $AdminAddress `
            -MaxRecordCount 2147483647

        $results = foreach ($schedule in $legacySchedules) {

            Convert-ToExportSafeObject `
                -InputObject $schedule `
                -PropertyNames @(
                    "Name",
                    "Uid",
                    "DesktopGroupName",
                    "DesktopGroupUid",
                    "Enabled",
                    "Frequency",
                    "StartTime",
                    "RebootDuration",
                    "WarningDuration",
                    "WarningMessage"
                )
        }

        return $results
    }

    Write-Log "No reboot schedule cmdlet found. Skipping reboot schedules." "Warning"

    return @()
}

