    $machines = Get-BrokerMachine -AdminAddress $AdminAddress -MaxRecordCount 2147483647

    foreach ($machine in $machines) {
        Convert-ToExportSafeObject -InputObject $machine -PropertyNames @(
            "MachineName",
            "DNSName",
            "Uid",
            "UUID",
            "CatalogName",
            "CatalogUid",
            "DesktopGroupName",
            "DesktopGroupUid",
            "HostedMachineName",
            "HypervisorConnectionName",
            "InMaintenanceMode",
            "IsAssigned",
            "IsPhysical",
            "MachineInternalState",
            "PowerState",
            "ProvisioningType",
            "RegistrationState",
            "SessionSupport",
            "Tags"
        )
    }
}

# =============================================================================
# 9. Relationship Resolver
# =============================================================================

function Resolve-CtxRelationships {
    param(
        [Parameter(Mandatory = $true)]
        [object]$ExportModel
    )

    Write-Log "Resolving cross-object relationships..." "Info"

    $relationships = [ordered]@{
        ApplicationsToDeliveryGroups = @()
        CatalogsToDeliveryGroups     = @()
    }

    $deliveryGroupLookup = @{}

    foreach ($dg in $ExportModel.DeliveryGroups) {
        if ($null -ne $dg.Uid) {
            $deliveryGroupLookup[[string]$dg.Uid] = $dg.Name
        }
    }

    foreach ($app in $ExportModel.Applications) {
        $associatedDgUids = $app.AssociatedDesktopGroupUids

        if ($null -eq $associatedDgUids) {
            continue
        }

        foreach ($dgUid in $associatedDgUids) {
            $relationships.ApplicationsToDeliveryGroups += [pscustomobject]@{
                ApplicationName   = $app.Name
                ApplicationUid    = $app.Uid
                DeliveryGroupUid  = $dgUid
                DeliveryGroupName = $deliveryGroupLookup[[string]$dgUid]
            }
        }
    }

    # Optional placeholder:
    # Catalog-to-DG mapping can vary depending on environment and whether
    # you want to map via machines, provisioning scheme metadata, or broker state.

    [pscustomobject]$relationships
}

# =============================================================================
# 10. Main Export Orchestration
# =============================================================================

function Invoke-CtxSiteExport {
    param(
        [string]$AdminAddress,
        [string]$OutputFolder,
        [string]$OutputXmlPath,
        [string]$ResourcesFolder,
        [bool]$IncludeNativeConfigXml,
        [bool]$IncludePolicyBinaryExport
    )

    Ensure-Folder -Path $OutputFolder
    Ensure-Folder -Path $ResourcesFolder

    Import-CitrixSdk

    Write-Log "Starting CVAD site export from AdminAddress [$AdminAddress]." "Info"
    Write-Log "Output XML path: $OutputXmlPath" "Info"
    Write-Log "Resources path:  $ResourcesFolder" "Info"

    $exportStarted = Get-Date

    $exportModel = [ordered]@{
        ExportMetadata = [pscustomobject]@{
            ExportedBy        = [Environment]::UserName
            ExportedFrom      = [Environment]::MachineName
            ExportStarted     = $exportStarted
            AdminAddress      = $AdminAddress
            OutputXmlPath     = $OutputXmlPath
            ResourcesFolder   = $ResourcesFolder
            FrameworkVersion  = "0.1.0-skeleton"
            ExportFormat      = "Custom-CVAD-CLIXML"
        }

        SiteProperties       = $null
        NativeConfigXml      = $null
        Tags                 = @()
        Administrators       = $null
        Zones                = @()
        Catalogs             = @()
        ProvisioningSchemes  = @()
        IdentityPools        = @()
        DeliveryGroups       = @()
        PowerManagement      = $null
        RebootSchedules      = @()
        ApplicationGroups    = @()
        Applications         = @()
        Machines             = @()
        Policies             = $null
        Relationships        = $null
        ExportSummary        = $null
    }

    try {
        $exportModel.SiteProperties      = Export-CtxSiteProperties -AdminAddress $AdminAddress
        $exportModel.Tags                = @(Export-CtxTags -AdminAddress $AdminAddress)
        $exportModel.Administrators      = Export-CtxAdministrators -AdminAddress $AdminAddress
        $exportModel.Zones               = @(Export-CtxZones -AdminAddress $AdminAddress)
        $exportModel.Catalogs            = @(Export-CtxCatalogs -AdminAddress $AdminAddress)
        $exportModel.ProvisioningSchemes = @(Export-CtxProvisioningSchemes -AdminAddress $AdminAddress)
        $exportModel.IdentityPools       = @(Export-CtxIdentityPools -AdminAddress $AdminAddress)
        $exportModel.DeliveryGroups      = @(Export-CtxDeliveryGroups -AdminAddress $AdminAddress)
        $exportModel.PowerManagement     = Export-CtxPowerManagement -AdminAddress $AdminAddress
        $exportModel.RebootSchedules     = @(Export-CtxRebootSchedules -AdminAddress $AdminAddress)
        $exportModel.ApplicationGroups   = @(Export-CtxApplicationGroups -AdminAddress $AdminAddress)
        $exportModel.Applications        = @(Export-CtxApplications -AdminAddress $AdminAddress -ResourcesFolder $ResourcesFolder)
        $exportModel.Machines            = @(Export-CtxMachines -AdminAddress $AdminAddress)
        $exportModel.Policies            = Export-CtxPolicies -AdminAddress $AdminAddress -IncludeBinaryExport:$IncludePolicyBinaryExport

        if ($IncludeNativeConfigXml) {
            $exportModel.NativeConfigXml = Export-CtxNativeConfigurationXml `
                -AdminAddress $AdminAddress `
                -Path $Script:NativeConfigPath
        }

        $exportModel.Relationships = Resolve-CtxRelationships -ExportModel ([pscustomobject]$exportModel)

        $exportCompleted = Get-Date

        $exportModel.ExportSummary = [pscustomobject]@{
            ExportCompleted              = $exportCompleted
            SiteName                     = $exportModel.SiteProperties.Name
            TagCount                     = @($exportModel.Tags).Count
            AdministratorCount           = @($exportModel.Administrators.Administrators).Count
            RoleCount                    = @($exportModel.Administrators.Roles).Count
            ScopeCount                   = @($exportModel.Administrators.Scopes).Count
            CatalogCount                 = @($exportModel.Catalogs).Count
            ProvisioningSchemeCount      = @($exportModel.ProvisioningSchemes).Count
            IdentityPoolCount            = @($exportModel.IdentityPools).Count
            DeliveryGroupCount           = @($exportModel.DeliveryGroups).Count
            RebootScheduleCount          = @($exportModel.RebootSchedules).Count
            ApplicationGroupCount        = @($exportModel.ApplicationGroups).Count
            ApplicationCount             = @($exportModel.Applications).Count
            MachineCount                 = @($exportModel.Machines).Count
            ApplicationIconExportedCount = @($exportModel.Applications | Where-Object {
                $_.IconResource -and $_.IconResource.Exported -eq $true
            }).Count
        }

        Write-Log "Serialising export model to XML..." "Info"

        [pscustomobject]$exportModel | Export-Clixml -Path $OutputXmlPath -Force -Depth 20

        Write-Log "CVAD export completed successfully." "Success"
        Write-Log "XML file:       $OutputXmlPath" "Success"
        Write-Log "Resources path: $ResourcesFolder" "Success"

        return [pscustomobject]@{
            Success         = $true
            OutputXmlPath   = $OutputXmlPath
            ResourcesFolder = $ResourcesFolder
            Summary         = $exportModel.ExportSummary
        }
    }
    catch {
        Write-Log "CVAD export failed: $($_.Exception.Message)" "Error"

        return [pscustomobject]@{
            Success         = $false
            OutputXmlPath   = $OutputXmlPath
            ResourcesFolder = $ResourcesFolder
            Error           = $_.Exception.Message
        }
    }
}

# =============================================================================
# 11. Execute
# =============================================================================

$result = Invoke-CtxSiteExport `
    -AdminAddress $AdminAddress `
    -OutputFolder $OutputFolder `
    -OutputXmlPath $Script:OutputXmlPath `
    -ResourcesFolder $Script:ResourcesFolder `
    -IncludeNativeConfigXml:$IncludeNativeConfigXml.IsPresent `
    -IncludePolicyBinaryExport:$IncludePolicyBinaryExport.IsPresent

$result
