function Export-CtxSiteProperties {
    param(
        [string]$AdminAddress
    )

    Write-Log "Collecting site properties..." "Info"

    $site = Get-BrokerSite -AdminAddress $AdminAddress

    $properties = @(
        "Name",
        "Uid",
        "LicenseServerName",
        "LicenseServerPort",
        "LicensingModel",
        "ProductCode",
        "ProductEdition",
        "MinimumFunctionalLevel",
        "DNSResolutionEnabled",
        "TrustRequestsSentToTheXmlServicePort",
        "LocalHostCacheEnabled",
        "ConfigLastChangeTime"
    )

    Convert-ToExportSafeObject -InputObject $site -PropertyNames $properties
}

function Export-CtxNativeConfigurationXml {
    param(
        [string]$AdminAddress,
        [string]$Path
    )

    if (-not (Get-Command Export-ConfigConfiguration -ErrorAction SilentlyContinue)) {
        Write-Log "Export-ConfigConfiguration cmdlet not found. Skipping native config XML export." "Warning"
        return $null
    }

    Write-Log "Exporting native Citrix site configuration XML..." "Info"

    try {
        $nativeXml = Export-ConfigConfiguration -AdminAddress $AdminAddress
        $nativeXml | Out-File -FilePath $Path -Encoding UTF8 -Force

        [pscustomobject]@{
            Exported = $true
            Path     = $Path
        }
    }
    catch {
        Write-Log "Native configuration XML export failed: $($_.Exception.Message)" "Warning"

        [pscustomobject]@{
            Exported = $false
            Path     = $Path
            Error    = $_.Exception.Message
        }
    }
}

