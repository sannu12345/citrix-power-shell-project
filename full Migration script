function Export-CtxApplications {
    param(
        [string]$AdminAddress,
        [string]$ResourcesFolder
    )

    Write-Log "Collecting published applications..." "Info"

    $applications = Get-BrokerApplication -AdminAddress $AdminAddress -MaxRecordCount 2147483647

    foreach ($app in $applications) {
        $iconUid = Get-SafeProperty -InputObject $app -PropertyName "IconUid"
        $iconResource = $null

        if ($null -ne $iconUid) {
            $iconResource = Export-CtxApplicationIcon `
                -AdminAddress $AdminAddress `
                -Application $app `
                -ResourcesFolder $ResourcesFolder
        }

        $appObject = Convert-ToExportSafeObject -InputObject $app -PropertyNames @(
            "Name",
            "Uid",
            "UUID",
            "ApplicationName",
            "PublishedName",
            "BrowserName",
            "Description",
            "Enabled",
            "Visible",
            "ApplicationType",
            "CommandLineExecutable",
            "CommandLineArguments",
            "WorkingDirectory",
            "ClientFolder",
            "StartMenuFolder",
            "AdminFolderName",
            "ShortcutAddedToDesktop",
            "ShortcutAddedToStartMenu",
            "UserFilterEnabled",
            "AssociatedUserNames",
            "AssociatedUserFullNames",
            "AssociatedUserUPNs",
            "AssociatedDesktopGroupUids",
            "AssociatedDesktopGroupUUIDs",
            "AssociatedDesktopGroupPriorities",
            "AssociatedApplicationGroupUids",
            "IconUid",
            "IconFromClient",
            "SecureCmdLineArgumentsEnabled",
            "CpuPriorityLevel",
            "WaitForPrinterCreation",
            "MetadataMap",
            "MetadataKeys",
            "Tags"
        )

        $appObject | Add-Member -MemberType NoteProperty -Name "IconResource" -Value $iconResource -Force

        $fta = Export-CtxApplicationFileTypeAssociations `
            -AdminAddress $AdminAddress `
            -Application $app

        $appObject | Add-Member -MemberType NoteProperty -Name "FileTypeAssociations" -Value $fta -Force

        $appObject
    }
}

function Export-CtxApplicationIcon {
    param(
        [string]$AdminAddress,

        [Parameter(Mandatory = $true)]
        [object]$Application,

        [string]$ResourcesFolder
    )

    $iconUid = Get-SafeProperty -InputObject $Application -PropertyName "IconUid"
    $appName = Get-SafeProperty -InputObject $Application -PropertyName "Name"

    if ($null -eq $iconUid) {
        return $null
    }

    if (-not (Get-Command Get-BrokerIcon -ErrorAction SilentlyContinue)) {
        Write-Log "Get-BrokerIcon not found. Cannot export icon for application [$appName]." "Warning"
        return $null
    }

    try {
        $icon = Get-BrokerIcon -AdminAddress $AdminAddress -Uid $iconUid
        $encodedIconData = Get-SafeProperty -InputObject $icon -PropertyName "EncodedIconData"

        if ([string]::IsNullOrWhiteSpace($encodedIconData)) {
            return [pscustomobject]@{
                Exported        = $false
                IconUid         = $iconUid
                FileName        = $null
                RelativePath    = $null
                Encoding        = "EncodedIconData"
                Error           = "No EncodedIconData returned."
            }
        }

        $safeAppName = Convert-ToSafeFileName -Name $appName
        $iconFileName = "$safeAppName`_$iconUid.txt"
        $iconPath = Join-Path $ResourcesFolder $iconFileName

        $encodedIconData | Out-File -FilePath $iconPath -Encoding ASCII -Force

        return [pscustomobject]@{
            Exported        = $true
            IconUid         = $iconUid
            FileName        = $iconFileName
            RelativePath    = ".\$ResourcesFolderName\$iconFileName"
            Encoding        = "EncodedIconData"
        }
    }
    catch {
        Write-Log "Failed to export icon for application [$appName]: $($_.Exception.Message)" "Warning"

        return [pscustomobject]@{
            Exported        = $false
            IconUid         = $iconUid
            FileName        = $null
            RelativePath    = $null
            Encoding        = "EncodedIconData"
            Error           = $_.Exception.Message
        }
    }
}

function Export-CtxApplicationFileTypeAssociations {
    param(
        [string]$AdminAddress,

        [Parameter(Mandatory = $true)]
        [object]$Application
    )

    $appUid  = Get-SafeProperty -InputObject $Application -PropertyName "Uid"
    $appName = Get-SafeProperty -InputObject $Application -PropertyName "Name"

    if (-not (Get-Command Get-BrokerConfiguredFTA -ErrorAction SilentlyContinue)) {
        Write-Log "Get-BrokerConfiguredFTA not found. Skipping FTAs for application [$appName]." "Debug"
        return @()
    }

    try {
        $ftas = Get-BrokerConfiguredFTA -AdminAddress $AdminAddress -ApplicationUid $appUid -MaxRecordCount 2147483647

        foreach ($fta in $ftas) {
            Convert-ToExportSafeObject -InputObject $fta -PropertyNames @(
                "Uid",
                "ApplicationUid",
                "ExtensionName",
                "HandlerName",
                "HandlerDescription",
                "HandlerOpenArguments",
                "HandlerOpenCommand",
                "HandlerIcon"
            )
        }
    }
    catch {
        Write-Log "Failed to collect FTAs for application [$appName]: $($_.Exception.Message)" "Warning"
        @()
    }
}

# =============================================================================
# 7. Policy Collector
# =============================================================================

function Export-CtxPolicies {
    param(
        [string]$AdminAddress,
        [bool]$IncludeBinaryExport
    )

    Write-Log "Collecting Citrix policy information..." "Info"

    $policyExport = [ordered]@{
        PolicySets           = @()
        ExportedPolicyBinary = $null
    }

    if (Get-Command Get-BrokerPolicySet -ErrorAction SilentlyContinue) {
        try {
            $policySets = Get-BrokerPolicySet -AdminAddress $AdminAddress -MaxRecordCount 2147483647

            $policyExport.PolicySets = foreach ($set in $policySets) {
                Convert-ToExportSafeObject -InputObject $set -PropertyNames @(
                    "Name",
                    "Guid",
                    "Description",
                    "IsDefault",
                    "Priority",
                    "Uid"
                )
            }
        }
        catch {
            Write-Log "Failed to collect policy sets: $($_.Exception.Message)" "Warning"
        }
    }
    else {
        Write-Log "Get-BrokerPolicySet not found. Skipping policy set enumeration." "Warning"
    }

    if ($IncludeBinaryExport) {
        if (-not (Get-Command Export-BrokerDesktopPolicy -ErrorAction SilentlyContinue)) {
            Write-Log "Export-BrokerDesktopPolicy not found. Skipping policy binary export." "Warning"
        }
        else {
            try {
                $policyBytes = Export-BrokerDesktopPolicy -AdminAddress $AdminAddress

                if ($null -ne $policyBytes) {
                    $base64 = [Convert]::ToBase64String($policyBytes)

                    $policyExport.ExportedPolicyBinary = [pscustomobject]@{
                        Exported = $true
                        Encoding = "Base64"
                        Data     = $base64
                    }
                }
                else {
                    $policyExport.ExportedPolicyBinary = [pscustomobject]@{
                        Exported = $false
                        Encoding = "Base64"
                        Data     = $null
                        Reason   = "No policy data returned."
                    }
                }
            }
            catch {
                Write-Log "Failed to export Citrix policy binary payload: $($_.Exception.Message)" "Warning"

                $policyExport.ExportedPolicyBinary = [pscustomobject]@{
                    Exported = $false
                    Encoding = "Base64"
                    Data     = $null
                    Error    = $_.Exception.Message
                }
            }
        }
    }

    [pscustomobject]$policyExport
}

